npx lint-staged

# Require a changeset if src/ files are being committed
SRC_CHANGED=$(git diff --cached --name-only -- 'src/' | head -1)
if [ -n "$SRC_CHANGED" ]; then
  CHANGESET=$(git diff --cached --name-only -- '.changeset/*.md' | grep -v README.md | head -1)
  if [ -z "$CHANGESET" ]; then
    echo ""
    echo "ERROR: Source files changed but no changeset found."
    echo "Run 'yarn changeset' to describe your change, then stage the file."
    echo ""
    exit 1
  fi
fi
