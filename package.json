{
  "name": "tripsheet",
  "version": "0.1.0",
  "description": "Self-hosted itinerary editor with Claude-powered research suggestions",
  "type": "module",
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "build": "tsc && node web/build.mjs",
    "build:web": "node web/build.mjs",
    "dev": "node scripts/dev.mjs",
    "dev:api": "tsx watch src/entrypoint.ts",
    "dev:web": "node web/build.mjs --watch",
    "init:local": "node scripts/init.mjs",
    "start": "node dist/entrypoint.js",
    "migrate": "tsx src/db/migrate.ts",
    "test": "node --max-old-space-size=4096 --experimental-vm-modules node_modules/.bin/jest",
    "test:watch": "node --max-old-space-size=4096 --experimental-vm-modules node_modules/.bin/jest --watch",
    "test:coverage": "node --max-old-space-size=4096 --experimental-vm-modules node_modules/.bin/jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'web/src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}' 'web/src/**/*.{ts,tsx}'",
    "changeset": "changeset",
    "release": "bash scripts/release.sh",
    "prepare": "husky"
  },
  "lint-staged": {
    "{src,web/src}/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "argon2": "^0.41.1",
    "better-sqlite3": "^11.8.1",
    "cookie-session": "^2.1.0",
    "dotenv": "^16.5.0",
    "express": "^5.2.1",
    "js-yaml": "^4.1.0",
    "multer": "^1.4.5-lts.1",
    "puppeteer-core": "^24.42.0",
    "react": "^19.1.0",
    "react-dom": "^19.2.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cookie-session": "^2.0.49",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-junit": "^16.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.2"
  }
}
