# Copy this file to .env and fill in real values. Never commit .env.

# Anthropic API key. Create one at https://console.anthropic.com/.
ANTHROPIC_API_KEY=

# Random string used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=

# Optional: override the default Claude model for AI suggestions.
# Defaults to the value in config.yaml or a sensible Sonnet release.
# ANTHROPIC_MODEL=claude-sonnet-4-5
